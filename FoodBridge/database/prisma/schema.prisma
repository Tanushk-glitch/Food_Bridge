generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  role             String     // DONOR, NGO, DELIVERY, ADMIN
  location         String?
  phone            String?
  organizationName String?
  passwordHash     String?
  passwordSalt     String?
  createdAt        DateTime   @default(now())
  donations        Donation[] @relation("DonorDonations")
  claims           Donation[] @relation("NgoClaims")
}

model Donation {
  id         String   @id @default(cuid())
  foodType   String
  quantity   String
  expiryTime String
  location   String
  status     String   @default("POSTED") // POSTED, ACCEPTED, PICKUP_SCHEDULED, PICKED_UP, DELIVERED
  donorId    String
  ngoId      String?
  createdAt  DateTime @default(now())
  donor      User     @relation("DonorDonations", fields: [donorId], references: [id])
  ngo        User?    @relation("NgoClaims", fields: [ngoId], references: [id])
}
