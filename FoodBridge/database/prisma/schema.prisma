generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DONOR
  NGO
  DELIVERY
}

enum UserStatus {
  active
  suspended
}

enum ReportStatus {
  open
  reviewing
  resolved
}

enum NotificationTargetRole {
  DONOR
  NGO
  DELIVERY
  ALL
}

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  role             UserRole   // ADMIN, DONOR, NGO, DELIVERY
  location         String?
  city             String?
  verified         Boolean    @default(false)
  status           UserStatus @default(active)
  phone            String?
  organizationName String?
  passwordHash     String?    // legacy (scrypt)
  passwordSalt     String?    // legacy (scrypt)
  passwordHashBcrypt String?  @map("password_hash")
  createdAt        DateTime   @default(now())
  donations        Donation[] @relation("DonorDonations")
  claims           Donation[] @relation("NgoClaims")
  reports          Report[]
}

model Donation {
  id         String   @id @default(cuid())
  foodType   String
  foodTitle  String?  @map("food_title")
  quantity   String
  expiryTime String
  location   String
  pickupStatus String? @map("pickup_status")
  status     String   @default("POSTED") // posted, claimed, pickup_in_progress, delivered, cancelled (legacy values may exist)
  locationLat Float?  @map("location_lat")
  locationLng Float?  @map("location_lng")
  donorId    String
  ngoId      String?
  createdAt  DateTime @default(now())
  donor      User     @relation("DonorDonations", fields: [donorId], references: [id])
  ngo        User?    @relation("NgoClaims", fields: [ngoId], references: [id])
  reports    Report[]
}

model Report {
  id          String       @id @default(cuid())
  donationId  String       @map("donation_id")
  reportedBy  String       @map("reported_by")
  description String
  status      ReportStatus @default(open)
  createdAt   DateTime     @default(now()) @map("created_at")

  donation Donation @relation(fields: [donationId], references: [id])
  reporter User     @relation(fields: [reportedBy], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  createdAt DateTime @default(now()) @map("created_at")
}

model Notification {
  id         String                 @id @default(cuid())
  title      String
  message    String
  targetRole NotificationTargetRole @map("target_role")
  createdAt  DateTime               @default(now()) @map("created_at")
}
