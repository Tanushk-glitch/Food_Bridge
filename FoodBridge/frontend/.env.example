BACKEND_URL=http://localhost:4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
AUTH_SECRET=change-me-in-production
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Demo-only: bypass backend auth to unblock UI (do not use in real production).
DEMO_LOGIN_BYPASS=false

# Demo-only: allow admin access in the frontend when email contains "admin".
# Recommended: keep `DEMO_ADMIN_ANY_PASSWORD=false` and set a shared password.
NEXT_PUBLIC_DEMO_ADMIN_BYPASS=false
DEMO_ADMIN_BYPASS=false
DEMO_ADMIN_ANY_PASSWORD=false
DEMO_ADMIN_PASSWORD=
# Optional: comma-separated allowlist. Blank = allow any email containing "admin".
DEMO_ADMIN_EMAIL_ALLOWLIST=
